{
  "manifest_version": 3,
  "name": "BikeHaus Kleinanzeigen Bulk Editor",
  "description": "Toplu olarak Kleinanzeigen ilanlarının açıklama bölümünü düzenler",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.kleinanzeigen.de/*",
    "https://api.[DOMAIN]/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.kleinanzeigen.de/*"],
      "js": ["content-edit.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}

